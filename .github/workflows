name: Build and deploy autonomous site

on:
  workflow_dispatch:
  schedule:
    - cron: "17 13 * * *"

permissions:
  contents: read
  pages: write
  id-token: write


jobs:
  build:
    runs-on: ubuntu-latest

    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Configure GitHub Pages
        uses: actions/configure-pages@v5

      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: "3.11"

      - name: Install dependencies
        run: pip install -q -U google-genai

      - name: Generate site
        env:
          GEMINI_API_KEY: ${{ secrets.GEMINI_API_KEY }}
          SITE_NAME: "Remote Work Tool Guide"
          NICHE: "budget-friendly productivity and home office tools for remote workers"
        run: |
          mkdir -p site/posts
          python <<'PY'
          import os
          import re
          import html
          import pathlib
          from datetime import datetime, timezone
          from google import genai

          site_name = os.environ["SITE_NAME"]
          niche = os.environ["NICHE"]
          now = datetime.now(timezone.utc)
          date_str = now.strftime("%Y-%m-%d")
          slug = f"{date_str}-daily-guide"

          client = genai.Client()

          prompt = f"""
          You are an autonomous niche-site operator.

          Niche: {niche}

          Create exactly one commercially useful article for a beginner audience.

          Return your answer in this exact plain-text format:

          TITLE: <title>
          DESCRIPTION: <155-character meta description>
          ARTICLE:
          <valid HTML fragment using only these tags: h2, h3, p, ul, ol, li, strong, em, a>

          Requirements:
          - 900 to 1400 words
          - helpful, specific, non-hype
          - focus on practical recommendations and comparisons
          - no medical, legal, or financial advice
          - do not invent prices, tests, or personal experience
          - do not use affiliate links yet
          - include one section called "Best for tight budgets"
          - include one section called "What to avoid"
          """

          response = client.models.generate_content(
              model="gemini-3-flash-preview",
              contents=prompt,
          )

          text = response.text.strip()

          title_match = re.search(r"TITLE:\s*(.+)", text)
          desc_match = re.search(r"DESCRIPTION:\s*(.+)", text)
          article_match = re.search(r"ARTICLE:\s*(.*)", text, re.S)

          title = title_match.group(1).strip() if title_match else f"{site_name} Daily Guide"
          description = desc_match.group(1).strip() if desc_match else "Helpful recommendations for remote workers."
          article_html = article_match.group(1).strip() if article_match else "<p>Content generation failed.</p>"

          safe_title = html.escape(title)
          safe_description = html.escape(description)

          post_html = f"""<!doctype html>
          <html lang="en">
          <head>
            <meta charset="utf-8">
            <meta name="viewport" content="width=device-width, initial-scale=1">
            <title>{safe_title}</title>
            <meta name="description" content="{safe_description}">
          </head>
          <body>
            <header>
              <h1>{safe_title}</h1>
              <p><a href="../index.html">Home</a></p>
              <p>Published {date_str}</p>
            </header>
            <main>
              {article_html}
            </main>
          </body>
          </html>"""

          index_html = f"""<!doctype html>
          <html lang="en">
          <head>
            <meta charset="utf-8">
            <meta name="viewport" content="width=device-width, initial-scale=1">
            <title>{html.escape(site_name)}</title>
            <meta name="description" content="Practical guides for budget-friendly remote work tools and home office setups.">
          </head>
          <body>
            <header>
              <h1>{html.escape(site_name)}</h1>
              <p>Autonomous publishing site focused on budget-friendly productivity and home office tools.</p>
            </header>
            <main>
              <h2>Latest article</h2>
              <p><a href="posts/{slug}.html">{safe_title}</a></p>
              <p>{safe_description}</p>
            </main>
          </body>
          </html>"""

          pathlib.Path("site/index.html").write_text(index_html, encoding="utf-8")
          pathlib.Path(f"site/posts/{slug}.html").write_text(post_html, encoding="utf-8")
          PY

      - name: Upload Pages artifact
        uses: actions/upload-pages-artifact@v4
        with:
          path: ./site

  deploy:
    environment:
      name: github-pages
      url: ${{ steps.deployment.outputs.page_url }}
    runs-on: ubuntu-latest
    needs: build

    steps:
      - name: Deploy to GitHub Pages
        id: deployment
        uses: actions/deploy-pages@v4
